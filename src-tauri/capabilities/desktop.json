{
  "identifier": "desktop-capability",
  "platforms": ["macOS", "windows", "linux"],
  "windows": [
    "main",
    "commit-*",
    "merge-*",
    "stash-*",
    "push-*",
    "settings",
    "pet",
    "pet-panel",
    "remote-workspace-*",
    "remote-settings-*",
    "remote-commit-*",
    "remote-merge-*",
    "remote-stash-*",
    "remote-push-*"
  ],
  "permissions": ["window-state:default"]
}
